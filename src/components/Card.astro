---
import GridBG from "./GridBG.astro";
---

<div
  class="gray-shadow-border | relative aspect-auto h-auto md:aspect-[16/7] max-w-[1400px] z-0 overflow-hidden mx-4 my-6 md:m-12 rounded-[1.5rem] md:rounded-[2.25rem] bg-white"
>
  <div class="-z-1 absolute inset-0">
    <div class="absolute -inset-[20%]">
      <GridBG columnCount="15" />
    </div>
    <div class="gray-gradient | absolute -inset-0 opacity-80"></div>
  </div>
  <slot />
</div>
