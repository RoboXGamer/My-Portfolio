---
import Scribble2 from "../Scribble2.astro";
---

<section id="services" class="relative px-4 md:px-16 lg:px-32 py-16 md:py-24">
  <!-- Title Area -->
  <div class="flex flex-col items-center text-center max-w-[900px] mx-auto mb-16 md:mb-24">
    <h2
      class="text-4xl leading-[1.2em] font-semibold tracking-[-0.04em] sm:text-5xl md:text-6xl lg:text-[72px]"
    >
      Your needs, my <span class="relative inline-block services-title-span">Expertise
        <Scribble2 />
      </span>
    </h2>
    <h2
      class="text-4xl leading-[1.2em] font-semibold tracking-[-0.04em] sm:text-5xl md:text-6xl lg:text-[72px]"
    >
      —let's make it happen.
    </h2>
    <p class="mt-8 text-base leading-[1.6em] tracking-[-0.01em] md:text-lg lg:text-xl max-w-[750px]">
      I offer services in web development, UI/UX design, and full-stack application
      development—delivering tailored solutions that bring your vision to life.
    </p>
  </div>

  <!-- Cards Container -->
  <div class="services-outer-container gray-shadow-border rounded-[1.5rem] md:rounded-[2.25rem] overflow-hidden bg-white p-4 md:p-8 max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
      <!-- Card 1: I Worked with -->
      <div id="worked-with-card" class="services-card relative flex flex-col rounded-[1rem] md:rounded-[1.25rem] bg-[#f5f5f5] p-8 md:p-12 min-h-[480px] md:min-h-[550px] overflow-hidden">
        <div class="relative z-10 select-none pointer-events-none">
          <h3 class="text-2xl md:text-[32px] font-semibold tracking-[-0.02em]">I Worked with:</h3>
          <p class="mt-2 text-sm md:text-base text-gray-500">I worked with different technologies and frameworks.</p>
        </div>
        <!-- Floating Draggable Pills -->
        <div class="absolute inset-0 select-none">
          <span class="services-pill worked-with-pill pill-purple" style="left: 8%; top: 38%; transform: rotate(-6deg);">TypeScript</span>
          <span class="services-pill worked-with-pill pill-yellow" style="left: 45%; top: 40%; transform: rotate(8deg);">JavaScript</span>
          <span class="services-pill worked-with-pill pill-red" style="left: 75%; top: 36%; transform: rotate(-4deg);">Java 21</span>
          <span class="services-pill worked-with-pill pill-orange" style="left: 12%; top: 52%; transform: rotate(5deg);">HTML</span>
          <span class="services-pill worked-with-pill pill-cyan" style="left: 36%; top: 54%; transform: rotate(-8deg);">CSS</span>
          <span class="services-pill worked-with-pill pill-blue" style="left: 62%; top: 50%; transform: rotate(12deg);">React 19</span>
          <span class="services-pill worked-with-pill pill-orange" style="left: 8%; top: 68%; transform: rotate(-10deg);">Astro 5</span>
          <span class="services-pill worked-with-pill pill-rose" style="left: 32%; top: 68%; transform: rotate(6deg);">NeoForge</span>
          <span class="services-pill worked-with-pill pill-violet" style="left: 58%; top: 66%; transform: rotate(-3deg);">Convex</span>
          <span class="services-pill worked-with-pill pill-pink" style="left: 76%; top: 70%; transform: rotate(-12deg);">PWA</span>
          <span class="services-pill worked-with-pill pill-teal" style="left: 18%; top: 82%; transform: rotate(4deg);">Git</span>
          <span class="services-pill worked-with-pill pill-gray" style="left: 45%; top: 82%; transform: rotate(-5deg);">GitHub</span>
          <span class="services-pill worked-with-pill pill-green" style="left: 72%; top: 84%; transform: rotate(8deg);">Gradle</span>
          <span class="services-pill worked-with-pill pill-emerald" style="left: 38%; top: 44%; transform: rotate(-2deg);">Netlify</span>
        </div>
      </div>

      <!-- Card 2: What I do -->
      <div id="what-i-do-card" class="services-card relative flex flex-col rounded-[1rem] md:rounded-[1.25rem] bg-[#f5f5f5] p-8 md:p-12 min-h-[480px] md:min-h-[550px] overflow-hidden">
        <div class="relative z-10 select-none pointer-events-none">
          <h3 class="text-2xl md:text-[32px] font-semibold tracking-[-0.02em]">What I do:</h3>
          <p class="mt-2 text-sm md:text-base text-gray-500">There are some of my different areas of work.</p>
        </div>
        <!-- Floating Draggable Pills -->
        <div class="absolute inset-0 select-none">
          <span class="services-pill what-i-do-pill pill-standard" style="left: 10%; top: 40%; transform: rotate(-5deg);">Full-Stack Web Development</span>
          <span class="services-pill what-i-do-pill pill-lime" style="left: 55%; top: 38%; transform: rotate(8deg);">Minecraft Modding</span>
          <span class="services-pill what-i-do-pill pill-pink" style="left: 15%; top: 56%; transform: rotate(10deg);">PWA Development</span>
          <span class="services-pill what-i-do-pill pill-blue" style="left: 60%; top: 54%; transform: rotate(-6deg);">Frontend Design</span>
          <span class="services-pill what-i-do-pill pill-green" style="left: 35%; top: 68%; transform: rotate(-8deg);">Real-Time Apps</span>
          <span class="services-pill what-i-do-pill pill-indigo" style="left: 8%; top: 80%; transform: rotate(12deg);">Scroll Animations</span>
          <span class="services-pill what-i-do-pill pill-red" style="left: 52%; top: 82%; transform: rotate(-4deg);">Responsive Design</span>
        </div>
      </div>
    </div>

    <!-- Tools Section -->
    <div class="flex flex-col items-center mt-8 md:mt-12 mb-4">
      <p class="text-sm md:text-base text-gray-500 mb-4 md:mb-6 select-none">The Tools I use!</p>
      <div class="flex flex-wrap justify-center gap-4 md:gap-5">
        <div class="tool-icon" title="VS Code">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg" alt="VS Code" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
        <div class="tool-icon" title="Git">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg" alt="Git" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
        <div class="tool-icon" title="Figma">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/figma/figma-original.svg" alt="Figma" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
        <div class="tool-icon" title="React">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg" alt="React" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
        <div class="tool-icon" title="TypeScript">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg" alt="TypeScript" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
        <div class="tool-icon" title="TailwindCSS">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg" alt="TailwindCSS" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
        <div class="tool-icon" title="Node.js">
          <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg" alt="Node.js" class="w-8 h-8 md:w-10 md:h-10" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .services-pill {
    position: absolute;
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border-radius: 16px;
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
    cursor: grab;
    user-select: none;
    touch-action: none; /* crucial for draggable touch interaction */
    z-index: 20;
    transition: transform 0.1s ease;
  }
  @media (min-width: 768px) {
    .services-pill {
      padding: 10px 24px;
      font-size: 14px;
      border-radius: 20px;
    }
  }
  .services-pill:active {
    cursor: grabbing;
  }

  /* 3D Skeuomorphic variants matching hero SVGs */
  .pill-purple {
    background: linear-gradient(180deg, #faf5ff 0%, #f3e8ff 100%);
    border: 1px solid rgba(192, 132, 252, 0.8);
    color: #7c3aed;
    box-shadow: inset 0 -4px 0.5px rgba(192, 132, 252, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(124, 58, 237, 0.04);
  }
  .pill-yellow {
    background: linear-gradient(180deg, #fefdf0 0%, #fef9c3 100%);
    border: 1px solid rgba(253, 224, 71, 0.8);
    color: #ca8a04;
    box-shadow: inset 0 -4px 0.5px rgba(253, 224, 71, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(202, 138, 4, 0.04);
  }
  .pill-red {
    background: linear-gradient(180deg, #fef2f2 0%, #fee2e2 100%);
    border: 1px solid rgba(252, 165, 165, 0.8);
    color: #dc2626;
    box-shadow: inset 0 -4px 0.5px rgba(252, 165, 165, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(220, 38, 38, 0.04);
  }
  .pill-orange {
    background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
    border: 1px solid rgba(253, 186, 116, 0.8);
    color: #ea580c;
    box-shadow: inset 0 -4px 0.5px rgba(253, 186, 116, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(234, 88, 12, 0.04);
  }
  .pill-cyan {
    background: linear-gradient(180deg, #ecfeff 0%, #cffafe 100%);
    border: 1px solid rgba(103, 232, 249, 0.8);
    color: #0891b2;
    box-shadow: inset 0 -4px 0.5px rgba(103, 232, 249, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(8, 145, 178, 0.04);
  }
  .pill-blue {
    background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid rgba(147, 197, 253, 0.8);
    color: #2563eb;
    box-shadow: inset 0 -4px 0.5px rgba(147, 197, 253, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(37, 99, 235, 0.04);
  }
  .pill-rose {
    background: linear-gradient(180deg, #fff1f2 0%, #ffe4e6 100%);
    border: 1px solid rgba(253, 164, 175, 0.8);
    color: #e11d48;
    box-shadow: inset 0 -4px 0.5px rgba(253, 164, 175, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(225, 29, 72, 0.04);
  }
  .pill-violet {
    background: linear-gradient(180deg, #f5f3ff 0%, #ddd6fe 100%);
    border: 1px solid rgba(196, 181, 253, 0.8);
    color: #4f46e5;
    box-shadow: inset 0 -4px 0.5px rgba(196, 181, 253, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(79, 70, 229, 0.04);
  }
  .pill-pink {
    background: linear-gradient(180deg, #fdf2f8 0%, #fce7f3 100%);
    border: 1px solid rgba(244, 114, 182, 0.8);
    color: #db2777;
    box-shadow: inset 0 -4px 0.5px rgba(244, 114, 182, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(219, 39, 119, 0.04);
  }
  .pill-teal {
    background: linear-gradient(180deg, #f0fdfa 0%, #ccfbf1 100%);
    border: 1px solid rgba(115, 237, 219, 0.8);
    color: #0d9488;
    box-shadow: inset 0 -4px 0.5px rgba(115, 237, 219, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(13, 148, 136, 0.04);
  }
  .pill-gray {
    background: linear-gradient(180deg, #fafafa 0%, #f0f0f0 100%);
    border: 1px solid rgba(209, 213, 219, 0.8);
    color: #4b5563;
    box-shadow: inset 0 -4px 0.5px rgba(209, 213, 219, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(75, 85, 99, 0.04);
  }
  .pill-green {
    background: linear-gradient(180deg, #f0fdf4 0%, #dcfce7 100%);
    border: 1px solid rgba(134, 239, 172, 0.8);
    color: #16a34a;
    box-shadow: inset 0 -4px 0.5px rgba(134, 239, 172, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(22, 163, 74, 0.04);
  }
  .pill-emerald {
    background: linear-gradient(180deg, #ecfdf5 0%, #d1fae5 100%);
    border: 1px solid rgba(110, 231, 183, 0.8);
    color: #059669;
    box-shadow: inset 0 -4px 0.5px rgba(110, 231, 183, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(5, 150, 105, 0.04);
  }
  .pill-lime {
    background: linear-gradient(180deg, #f7fee7 0%, #ecfccb 100%);
    border: 1px solid rgba(190, 242, 93, 0.8);
    color: #65a30d;
    box-shadow: inset 0 -4px 0.5px rgba(190, 242, 93, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(101, 163, 13, 0.04);
  }
  .pill-indigo {
    background: linear-gradient(180deg, #eef2ff 0%, #e0e7ff 100%);
    border: 1px solid rgba(165, 180, 252, 0.8);
    color: #4f46e5;
    box-shadow: inset 0 -4px 0.5px rgba(165, 180, 252, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(79, 70, 229, 0.04);
  }

  .pill-standard {
    background: linear-gradient(180deg, #ffffff 0%, #f8f8f8 100%);
    border: 1px solid rgba(200, 200, 200, 0.8);
    color: #1f1f1f;
    box-shadow: inset 0 -4px 0.5px rgba(188, 188, 188, 0.3), inset 0 2px 0.5px 0 #ffffff, 0 6px 15px rgba(0, 0, 0, 0.04);
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: rgb(245, 245, 245);
    border: 1px solid rgb(230, 230, 230);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: default;
  }
  .tool-icon:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 768px) {
    .tool-icon {
      width: 80px;
      height: 80px;
      border-radius: 20px;
    }
  }

  .services-title-span :global(svg) {
    width: 105% !important;
    height: auto !important;
    top: auto !important;
    bottom: -10px !important;
  }
  @media (min-width: 768px) {
    .services-title-span :global(svg) {
      bottom: -16px !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";
  gsap.registerPlugin(Draggable);

  // Initialize Draggable for worked-with pills
  Draggable.create(".worked-with-pill", {
    bounds: document.getElementById("worked-with-card"),
    inertia: true,
    edgeResistance: 0.65,
    onDragStart: function() {
      gsap.to(this.target, { scale: 1.08, duration: 0.2 });
    },
    onDragEnd: function() {
      gsap.to(this.target, { scale: 1, duration: 0.2 });
    }
  });

  // Initialize Draggable for what-i-do pills
  Draggable.create(".what-i-do-pill", {
    bounds: document.getElementById("what-i-do-card"),
    inertia: true,
    edgeResistance: 0.65,
    onDragStart: function() {
      gsap.to(this.target, { scale: 1.08, duration: 0.2 });
    },
    onDragEnd: function() {
      gsap.to(this.target, { scale: 1, duration: 0.2 });
    }
  });
</script>
