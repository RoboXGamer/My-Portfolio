---
import Card from "./Card.astro";
import Button from "./Button.astro";

const { title, subTitle = "", description, imgSrc, githubUrl = "#" } = Astro.props;
---

<div class="min-h-screen md:h-screen grid place-content-center py-8 md:py-0 | work-card">
  <Card>
    <div class="main-grid">
      <div class="flex justify-center gap-4 md:gap-6 h-full flex-col px-6 pb-6 pt-2 md:px-12 md:py-0 order-2 md:order-1">
        <div class="flex flex-col gap-1 md:gap-2">
          <h2 class="text-2xl md:text-3xl font-bold">{title}</h2>
          <p class="text-sm sm:text-base md:text-2xl text-gray">{subTitle}</p>
        </div>
        <p class="text-sm md:text-md font-bold mt-2 md:mt-4">Project Description:</p>
        <p class="text-sm md:text-base font-[500] max-w-full md:max-w-[90%]">
          {description}
        </p>
        <a href={githubUrl} target="_blank"><Button size="sm">View on GitHub</Button></a>
      </div>
      <div class="grid place-items-center h-full p-6 pb-2 md:p-6 min-h-0 order-1 md:order-2">
        <div class="w-full h-full aspect-[4/3] md:aspect-auto rounded-[1rem] overflow-hidden">
          <img src={imgSrc} alt="" />
        </div>
      </div>
    </div>

    <style>
      .main-grid {
        width: 100%;
        height: 100%;
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: auto auto;
        gap: 0.5rem;
      }
      @media (min-width: 768px) {
        .main-grid {
          grid-template-columns: 1.2fr 2fr;
          grid-template-rows: 1fr;
          gap: 1rem;
        }
      }
      img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
    </style>
  </Card>
</div>

<style>
  .text-gray {
    color: rgb(166, 166, 166);
  }
</style>
